{
  "manifest_version": 3,
  "name": "Word Store vocabulary",
  "version": "1.0.0",
  "description": "A Chrome extension to manage and practice vocabulary using Word Store.",
  "icons": {
    "16": "public/vite.svg"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "public/vite.svg"
    }
  },
  "content_scripts": [
    {
      "js": [
        "assets/Content.tsx-loader-DXnpTuaf.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "assets/Content-C186FUZv.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/useChromeStorage-DuXms8TS.js",
        "assets/Content.tsx-D6fehsg4.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
